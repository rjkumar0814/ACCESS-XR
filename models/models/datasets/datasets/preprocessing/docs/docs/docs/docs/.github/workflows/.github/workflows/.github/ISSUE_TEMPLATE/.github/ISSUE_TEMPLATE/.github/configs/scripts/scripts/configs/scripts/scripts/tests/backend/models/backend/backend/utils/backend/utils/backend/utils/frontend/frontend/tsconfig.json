{
  "compilerOptions": {
    "target": "ES2022",

    "useDefineForClassFields": true,

    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],

    "allowJs": false,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "strict": true,

    "forceConsistentCasingInFileNames": true,

    "noFallthroughCasesInSwitch": true,

    "module": "ESNext",

    "moduleResolution": "Node",

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noEmit": true,

    "jsx": "react-jsx",

    "baseUrl": "./src",

    "paths": {

      "@/*": [
        "*"
      ],

      "@/components/*": [
        "components/*"
      ],

      "@/pages/*": [
        "pages/*"
      ],

      "@/services/*": [
        "services/*"
      ],

      "@/hooks/*": [
        "hooks/*"
      ],

      "@/layouts/*": [
        "layouts/*"
      ],

      "@/store/*": [
        "store/*"
      ],

      "@/utils/*": [
        "utils/*"
      ],

      "@/types/*": [
        "types/*"
      ],

      "@/assets/*": [
        "assets/*"
      ]

    },

    "types": [
      "vite/client"
    ]
  },

  "include": [

    "src"

  ],

  "references": [

    {
      "path": "./tsconfig.node.json"
    }

  ]
}
